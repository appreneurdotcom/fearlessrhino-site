# Copy this file to .env and fill in real values before running the site.
# Never commit your real .env file — it holds passwords and API keys.

# ---- Server ----
PORT=3000
# Any long random string — used to sign admin login sessions.
SESSION_SECRET=change-this-to-a-long-random-string

# ---- Public site address ----
# Used to build the full URLs in the admin "download domain list" export,
# and inside inquiry emails. Set this to your real live domain once launched.
APP_BASE_URL=https://fearlessrhino.com

# ---- Admin login (for /admin, the domain-list upload screen) ----
# Simplest option: set a plain password here.
ADMIN_PASSWORD=change-me-now
# More secure option: instead of ADMIN_PASSWORD above, set a bcrypt hash here
# (generate one with: node -e "console.log(require('bcryptjs').hashSync('yourpassword', 10))")
# ADMIN_PASSWORD_HASH=

# ---- Where inquiry & contact-form emails get delivered ----
EMAIL_TO=hello@fearlessrhino.com
EMAIL_FROM="Fearless Rhino Website <website@fearlessrhino.com>"

# ---- Email sending: pick ONE of the two options below ----

# Option A — Resend (https://resend.com). Free tier, easiest to set up:
# sign up, verify a sending domain (or use their onboarding@resend.dev for
# testing), create an API key, paste it here.
# RESEND_API_KEY=

# Option B — SMTP (Gmail, Zoho, your registrar's mailbox, etc.)
# For Gmail: turn on 2-Step Verification, then create an "App Password" at
# https://myaccount.google.com/apppasswords and use it as SMTP_PASS below.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=

# If neither RESEND_API_KEY nor SMTP_HOST is set, the site still runs and
# every inquiry is safely recorded in the admin panel's inquiry log — it
# just won't be emailed to you until you configure one of the options above.
